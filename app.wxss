/* app.wxss — 全局样式 */
page {
  --primary: #FF6B35;
  --primary-light: #FF8C5A;
  --primary-dark: #E55A28;
  --bg: #F7F7F7;
  --card-bg: #FFFFFF;
  --text-primary: #1A1A1A;
  --text-secondary: #666666;
  --text-placeholder: #BBBBBB;
  --border: #EEEEEE;
  --safe-bottom: env(safe-area-inset-bottom);
  --token-income: #FF6B53;
  --token-expense: #07C160;

  background-color: var(--bg);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  font-size: 28rpx;
  color: var(--text-primary);
}

/* ========== 通用工具类 ========== */
.flex { display: flex; }
.flex-col { display: flex; flex-direction: column; }
.flex-center { display: flex; align-items: center; justify-content: center; }
.flex-between { display: flex; align-items: center; justify-content: space-between; }
.flex-1 { flex: 1; }
.gap-8 { gap: 8rpx; }
.gap-12 { gap: 12rpx; }
.gap-16 { gap: 16rpx; }
.gap-24 { gap: 24rpx; }

.mt-8  { margin-top: 8rpx; }
.mt-12 { margin-top: 12rpx; }
.mt-16 { margin-top: 16rpx; }
.mt-24 { margin-top: 24rpx; }
.mt-32 { margin-top: 32rpx; }
.mb-12 { margin-bottom: 12rpx; }
.mb-16 { margin-bottom: 16rpx; }
.mb-24 { margin-bottom: 24rpx; }
.p-16  { padding: 16rpx; }
.p-24  { padding: 24rpx; }
.px-24 { padding-left: 24rpx; padding-right: 24rpx; }
.py-16 { padding-top: 16rpx; padding-bottom: 16rpx; }

.text-primary { color: var(--primary); }
.text-secondary { color: var(--text-secondary); }
.text-sm { font-size: 24rpx; }
.text-xs { font-size: 22rpx; }
.text-lg { font-size: 36rpx; }
.text-xl { font-size: 42rpx; }
.text-bold { font-weight: 600; }
.text-center { text-align: center; }
.line-clamp-2 {
  overflow: hidden;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

/* ========== 卡片 ========== */
.card {
  background: var(--card-bg);
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  margin: 16rpx 24rpx;
}

/* ========== 按钮 ========== */
.btn-primary {
  background: var(--primary);
  color: #FFFFFF;
  border-radius: 44rpx;
  height: 88rpx;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 53, 0.35);
  transition: all 0.2s;
}
.btn-primary:active {
  transform: scale(0.97);
  box-shadow: 0 2rpx 8rpx rgba(255, 107, 53, 0.25);
}
.btn-primary::after { border: none; }

.btn-outline {
  background: transparent;
  color: var(--primary);
  border: 2rpx solid var(--primary);
  border-radius: 44rpx;
  height: 88rpx;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}
.btn-outline::after { border: none; }

.btn-disabled {
  background: #DDDDDD;
  color: #999999;
  border-radius: 44rpx;
  height: 88rpx;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: none;
}
.btn-disabled::after { border: none; }

/* ========== 输入框 ========== */
.input-wrap {
  background: #F9F9F9;
  border: 2rpx solid var(--border);
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 28rpx;
  transition: border-color 0.2s;
}
.input-wrap:focus-within {
  border-color: var(--primary);
  background: #FFFFFF;
}
.input-wrap textarea {
  width: 100%;
  border: none;
  background: transparent;
  font-size: 28rpx;
  line-height: 1.6;
  color: var(--text-primary);
  outline: none;
  resize: none;
}
.input-wrap .input-label {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
}

/* ========== Tab 切换 ========== */
.tab-bar {
  display: flex;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 6rpx;
  gap: 6rpx;
  margin: 0 24rpx 16rpx;
}
.tab-item {
  flex: 1;
  height: 72rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-secondary);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.25s;
}
.tab-item.active {
  background: var(--primary);
  color: #FFFFFF;
  font-weight: 600;
}

/* ========== 积分徽章 ========== */
.token-badge {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  background: linear-gradient(135deg, #FF6B35, #FF8C5A);
  color: #FFFFFF;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 600;
}

/* ========== 骨架屏 ========== */
.skeleton {
  background: linear-gradient(90deg, #F0F0F0 25%, #E0E0E0 50%, #F0F0F0 75%);
  background-size: 200% 100%;
  animation: skeleton-loading 1.4s ease infinite;
  border-radius: 8rpx;
}
@keyframes skeleton-loading {
  0%   { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* ========== 分隔线 ========== */
.divider {
  height: 1rpx;
  background: var(--border);
  margin: 24rpx 0;
}

/* ========== 空状态 ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 60rpx;
}
.empty-state .empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}
.empty-state .empty-text {
  font-size: 28rpx;
  color: var(--text-secondary);
  text-align: center;
}

/* ========== 积分颜色样式 ========== */
.token-income {
  color: var(--token-income);
}
.token-expense {
  color: var(--token-expense);
}

/* ========== 安全区底部 ========== */
.safe-bottom {
  padding-bottom: calc(var(--safe-bottom) + 20rpx);
}
