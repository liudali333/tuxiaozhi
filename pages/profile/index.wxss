/* pages/profile/index.wxss */

.page-profile {
  min-height: 100vh;
  background: var(--bg);
}

/* ── 顶部头部 ──────────────────────────────────────── */
.profile-header {
  background: linear-gradient(135deg, #FF6B35 0%, #FF8C5A 100%);
  padding: 40rpx 32rpx;
}

.user-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.4);
  background: #eeeeee;
  flex-shrink: 0;
}

.user-info {
  flex: 1;
  min-width: 0;
}

.user-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 10rpx;
}

.user-id {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.75);
  word-break: break-all;
}

.user-level {
  background: rgba(255, 255, 255, 0.25);
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 700;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.35);
}

.user-balance-action {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

.user-balance-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.user-balance-num {
  font-size: 48rpx;
  font-weight: 800;
  color: #ffffff;
  line-height: 1;
}

.user-balance-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
}

.recharge-btn {
  background: #ffffff;
  color: #FF6B35;
  border-radius: 32rpx;
  padding: 10rpx 28rpx;
  font-size: 24rpx;
  font-weight: 600;
  border: none;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  white-space: nowrap;
  line-height: 1.4;
}

.recharge-btn::after {
  border: none;
}

/* ── 签到卡片 ──────────────────────────────────────── */
.sign-card {
  background: linear-gradient(135deg, #FFE066 0%, #FFD23F 100%);
  margin: 24rpx;
  border-radius: 20rpx;
  padding: 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 4rpx 16rpx rgba(255, 210, 63, 0.25);
}

.sign-card-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.sign-icon {
  font-size: 48rpx;
}

.sign-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.sign-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #8B4513;
}

.sign-desc {
  font-size: 24rpx;
  color: #A0522D;
}

.sign-btn {
  background: linear-gradient(135deg, #FF8C5A 0%, #FF6B35 100%);
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 600;
  padding: 16rpx 32rpx;
  border-radius: 40rpx;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 53, 0.3);
  white-space: nowrap;
}

.sign-btn.signed {
  background: #B0BEC5;
  color: #607D8B;
  box-shadow: none;
}

.sign-btn::after {
  border: none;
}

/* ── 菜单列表 ──────────────────────────────────────── */
.menu-list {
  background: #ffffff;
  padding: 0;
  margin: 24rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: #F8F8F8;
}

.menu-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.menu-icon-wrap {
  width: 56rpx;
  height: 56rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.menu-icon {
  font-size: 28rpx;
}

.menu-text {
  font-size: 30rpx;
  color: #333333;
  font-weight: 500;
}

.menu-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.menu-desc {
  font-size: 24rpx;
  color: #999999;
}

.menu-arrow {
  font-size: 32rpx;
  color: #CCCCCC;
}

.menu-item-btn {
  width: 100%;
  display: flex !important;
  align-items: center !important;
  justify-content: space-between !important;
  padding: 28rpx 32rpx;
  background: transparent;
  border: none;
  font-size: inherit;
  text-align: left !important;
  line-height: normal !important;
}

.menu-item-btn::after {
  border: none;
}

/* ── 客服按钮 ──────────────────────────────────────── */
.contact-btn {
  text-align: left !important;
  line-height: normal !important;
  display: flex !important;
  align-items: center !important;
  justify-content: space-between !important;
  padding: 28rpx 32rpx !important;
  width: 100% !important;
  box-sizing: border-box !important;
}

.contact-btn::after {
  border: none !important;
  display: none !important;
}

.contact-btn::before {
  display: none !important;
}

.contact-btn:active {
  background: #F8F8F8;
}

.contact-btn .menu-left {
  display: flex !important;
  align-items: center !important;
  gap: 20rpx !important;
  justify-content: flex-start !important;
  flex: 1 !important;
  text-align: left !important;
}

.contact-btn .menu-right {
  display: flex !important;
  align-items: center !important;
  gap: 12rpx !important;
  justify-content: flex-end !important;
  flex-shrink: 0 !important;
}

.contact-btn .menu-icon-wrap {
  justify-content: center !important;
}

.contact-btn .menu-text {
  text-align: left !important;
}

.contact-btn .menu-icon {
  text-align: center !important;
}

.contact-btn .menu-arrow {
  text-align: right !important;
}

/* ── 登录卡片 ──────────────────────────────────────── */
.login-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx;
}

.login-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.login-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 12rpx;
}

.login-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 40rpx;
}

.login-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  background: #FFFFFF;
  color: #FF6B35;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  padding: 24rpx 60rpx;
  border: none;
  line-height: 1;
  min-width: 400rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
}

.login-btn::after {
  border: none;
}

.login-btn[disabled] {
  opacity: 0.7;
}

.login-btn-icon {
  font-size: 40rpx;
}

.login-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  margin-top: 32rpx;
  color: rgba(255, 255, 255, 0.9);
  font-size: 26rpx;
}

.loading-spinner {
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.4);
  border-top-color: #FFFFFF;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* ── 退出登录 ─────────────────────────────────────────── */
.logout-section {
  padding: 24rpx 24rpx 48rpx;
}

.logout-btn {
  background: #ffffff;
  color: #FF5252;
  border: 2rpx solid #FFE0E0;
  border-radius: 48rpx;
  padding: 24rpx 48rpx;
  font-size: 28rpx;
  font-weight: 600;
  width: 100%;
  box-shadow: 0 2rpx 12rpx rgba(255, 82, 82, 0.08);
}

.logout-btn::after {
  border: none;
}

.logout-btn:active {
  background: #FFF5F5;
}

/* ── 头像预览 ──────────────────────────────────────── */
.avatar-preview-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 20rpx;
}

.avatar-preview {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.4);
  border: 4rpx solid rgba(255,255,255,0.5);
}

.avatar-preview-text {
  font-size: 24rpx;
  color: rgba(255,255,255,0.7);
  margin-top: 12rpx;
}

/* ── 登录中提示 ──────────────────────────────────────── */
.login-loading-text {
  margin-top: 24rpx;
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.login-loading-text::before {
  content: '';
  width: 28rpx;
  height: 28rpx;
  border: 3rpx solid rgba(255,255,255,0.5);
  border-top-color: #FFFFFF;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* ── 禁用状态按钮样式 ──────────────────────────────────── */
.wx-login-btn[disabled] {
  opacity: 0.7;
  background: rgba(255,255,255,0.7);
}

/* ── 头像昵称设置弹窗 ──────────────────────────────────── */
.profile-setup-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.modal-content {
  position: relative;
  width: 600rpx;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  z-index: 1;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333333;
  text-align: center;
  margin-bottom: 12rpx;
}

.modal-desc {
  font-size: 26rpx;
  color: #999999;
  text-align: center;
  margin-bottom: 40rpx;
}

.profile-setup-form {
  margin-bottom: 40rpx;
}

.avatar-setup {
  display: flex;
  justify-content: center;
  margin-bottom: 32rpx;
}

.avatar-btn {
  background: transparent;
  padding: 0;
  margin: 0;
  border: none;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-btn::after {
  border: none;
}

.avatar-preview {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: #f5f5f5;
  border: 4rpx dashed #dddddd;
}

.avatar-tip {
  font-size: 24rpx;
  color: #999999;
  margin-top: 12rpx;
}

.nickname-setup {
  padding: 0 20rpx;
}

.nickname-input {
  width: 100%;
  height: 88rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: #333333;
  text-align: center;
}

.modal-btn {
  width: 100%;
  height: 88rpx;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  margin: 0;
}

.modal-btn::after {
  border: none;
}

.confirm-btn {
  background: linear-gradient(135deg, #FF6B35 0%, #FF8C5A 100%);
  color: #ffffff;
}

.confirm-btn[disabled] {
  opacity: 0.5;
}
