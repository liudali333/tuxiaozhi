/* pages/generate/index.wxss */
.page-generate {
  min-height: 100vh;
  background: var(--bg);
  padding-bottom: 160rpx;
}
.page-header {
  background: linear-gradient(135deg, #FF6B35 0%, #FF8C5A 100%);
  padding: 40rpx 32rpx;
  color: #fff;
}
.page-title {
  font-size: 40rpx;
  font-weight: 800;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.page-sub {
  font-size: 26rpx;
  opacity: 0.85;
}
.card {
  background: #fff;
  margin: 16rpx 24rpx;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}
.section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}
.ratio-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12rpx;
}
.ratio-item {
  border: 2rpx solid var(--border);
  border-radius: 12rpx;
  padding: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  cursor: pointer;
  transition: all 0.2s;
}
.ratio-item.active {
  border-color: var(--primary);
  background: rgba(255,107,53,0.05);
}
.ratio-label { font-size: 26rpx; font-weight: 600; }
.ratio-desc { font-size: 21rpx; color: var(--text-secondary); }
.style-chips { display: flex; flex-wrap: wrap; gap: 12rpx; }
.style-chip {
  padding: 10rpx 20rpx;
  border: 2rpx solid var(--border);
  border-radius: 32rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  cursor: pointer;
  transition: all 0.2s;
}
.style-chip.active {
  border-color: var(--primary);
  background: rgba(255,107,53,0.08);
  color: var(--primary);
  font-weight: 600;
}
.bg-scroll { display: flex; gap: 16rpx; white-space: nowrap; }
.bg-swatch {
  flex-shrink: 0;
  width: 110rpx;
  height: 110rpx;
  border-radius: 12rpx;
  border: 3rpx solid transparent;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  position: relative;
  cursor: pointer;
  transition: all 0.2s;
}
.bg-swatch.active { border-color: var(--primary); box-shadow: 0 0 0 4rpx rgba(255,107,53,0.15); }
.bg-label { font-size: 22rpx; color: #666; }
.dark-label { color: rgba(255,255,255,0.8); }
.bg-check {
  position: absolute; top: 4rpx; right: 4rpx;
  width: 26rpx; height: 26rpx;
  background: var(--primary);
  color: #fff;
  border-radius: 50%;
  font-size: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.module-list { display: flex; flex-direction: column; gap: 12rpx; }
.module-item {
  display: flex; align-items: center; gap: 12rpx;
  padding: 20rpx;
  border: 2rpx solid var(--border);
  border-radius: 12rpx;
  cursor: pointer;
  transition: all 0.2s;
}
.module-item.active { border-color: var(--primary); background: rgba(255,107,53,0.05); }
.module-icon { font-size: 32rpx; width: 40rpx; text-align: center; }
.module-text { flex: 1; font-size: 28rpx; }
.module-check {
  width: 36rpx; height: 36rpx;
  border-radius: 50%;
  border: 2rpx solid var(--border);
  display: flex; align-items: center; justify-content: center;
  font-size: 22rpx; color: var(--primary);
  transition: all 0.2s;
}
.module-item.active .module-check { background: var(--primary); border-color: var(--primary); color: #fff; }
.count-row { display: flex; align-items: center; justify-content: space-between; }
.count-tip { font-size: 26rpx; color: var(--text-secondary); }
.stepper { display: flex; align-items: center; gap: 24rpx; }
.step-btn {
  width: 56rpx; height: 56rpx;
  border-radius: 50%;
  border: 2rpx solid var(--border);
  display: flex; align-items: center; justify-content: center;
  font-size: 36rpx; font-weight: 700; color: var(--text-secondary);
  cursor: pointer;
}
.step-num { font-size: 36rpx; font-weight: 700; min-width: 48rpx; text-align: center; }
.cost-tip { text-align: right; font-size: 24rpx; color: var(--text-placeholder); margin-top: 12rpx; }
.bottom-bar {
  position: fixed; bottom: 0; left: 0; right: 0;
  background: #fff;
  padding: 16rpx 32rpx calc(16rpx + env(safe-area-inset-bottom));
  display: flex; align-items: center; justify-content: space-between;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.07);
  z-index: 100;
}
.cost-info { font-size: 26rpx; color: var(--text-secondary); }
.cost-num { color: var(--primary); font-weight: 700; font-size: 30rpx; }
.gen-btn {
  width: 260rpx; height: 88rpx; border-radius: 44rpx;
  background: var(--primary); color: #fff;
  font-size: 32rpx; font-weight: 700;
  border: none; box-shadow: 0 4rpx 16rpx rgba(255,107,53,0.35);
  display: flex; align-items: center; justify-content: center;
}
.gen-btn::after { border: none; }
