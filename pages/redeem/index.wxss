/* pages/redeem/index.wxss */

.page-redeem {
  min-height: 100vh;
  background: var(--bg);
}

/* ── 卡片 ──────────────────────────────────────────── */
.card {
  margin: 24rpx;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 40rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.06);
}

.card-icon {
  font-size: 72rpx;
  margin-bottom: 4rpx;
}

.card-title {
  font-size: 38rpx;
  font-weight: 800;
  color: var(--text-primary);
}

.card-sub {
  font-size: 26rpx;
  color: var(--text-secondary);
  text-align: center;
  line-height: 1.5;
  margin-bottom: 12rpx;
}

/* ── 兑换码输入框 ─────────────────────────────────── */
.code-input-wrap {
  width: 100%;
  background: #f9f9f9;
  border: 3rpx solid var(--border);
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  transition: all 0.2s;
  margin-top: 8rpx;
}

.code-input-wrap.active {
  border-color: var(--primary);
  background: #ffffff;
}

.code-input {
  flex: 1;
  font-size: 34rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
  color: var(--text-primary);
  outline: none;
  border: none;
  background: transparent;
}

.code-placeholder {
  color: var(--text-placeholder);
  font-size: 30rpx;
  font-weight: 400;
  letter-spacing: 0;
}

.code-clear {
  width: 40rpx;
  height: 40rpx;
  background: #cccccc;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  color: #ffffff;
  flex-shrink: 0;
}

/* ── 格式提示 ─────────────────────────────────────── */
.code-hint {
  width: 100%;
  font-size: 24rpx;
  text-align: right;
  margin-top: -4rpx;
}

.hint-ok {
  color: #52c41a;
  font-weight: 600;
}

.hint-warn {
  color: var(--text-placeholder);
}

/* ── 兑换按钮 ─────────────────────────────────────── */
.redeem-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 48rpx;
  background: var(--primary);
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 700;
  border: none;
  box-shadow: 0 6rpx 20rpx rgba(255, 107, 53, 0.35);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 8rpx;
}

.redeem-btn::after {
  border: none;
}

.redeem-btn[disabled] {
  background: #dddddd;
  box-shadow: none;
  color: #999999;
}

/* ── 示例说明 ─────────────────────────────────────── */
.example-card {
  margin: 16rpx 24rpx;
  align-items: flex-start;
  padding: 28rpx;
}

.example-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

.example-item {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 2;
}

/* ── 成功页 ───────────────────────────────────────── */
.success-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 32rpx 40rpx;
}

.success-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
  animation: bounce 0.6s ease;
}

@keyframes bounce {
  0%   { transform: scale(0.5); opacity: 0; }
  60%  { transform: scale(1.1); }
  100% { transform: scale(1);   opacity: 1; }
}

.success-title {
  font-size: 44rpx;
  font-weight: 800;
  color: var(--primary);
  margin-bottom: 12rpx;
}

.success-sub {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
}

.success-tokens {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  margin: 16rpx 0;
}

.token-emoji {
  font-size: 48rpx;
}

.token-num {
  font-size: 72rpx;
  font-weight: 800;
  color: var(--primary);
}

.token-unit {
  font-size: 32rpx;
  color: var(--primary);
  font-weight: 600;
}

.success-tip {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 60rpx;
}

.success-actions {
  display: flex;
  gap: 20rpx;
  width: 100%;
}

.success-actions .btn-outline,
.success-actions .btn-primary {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.success-actions .btn-outline {
  border: 2rpx solid var(--primary);
  color: var(--primary);
  background: transparent;
}

.success-actions .btn-primary {
  background: var(--primary);
  color: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 53, 0.3);
}

.success-actions button::after {
  border: none;
}
