<view class="page-recharge-history">
  <view class="stats-bar">
    <view class="stat-item">
      <text class="stat-num">{{list.length}}</text>
      <text class="stat-label">充值笔数</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-num">¥{{totalAmount}}</text>
      <text class="stat-label">累计充值</text>
    </view>
  </view>

  <view wx:if="{{!loading && list.length === 0}}" class="empty-state">
    <view class="empty-icon">💰</view>
    <view class="empty-title">暂无充值记录</view>
    <view class="empty-sub">快去充值积分开始创作吧</view>
    <button class="btn-primary empty-btn" bindtap="goRecharge">去充值</button>
  </view>

  <view wx:else class="recharge-list">
    <view
      wx:for="{{list}}"
      wx:key="orderId"
      class="recharge-card"
    >
      <view class="card-left">
        <view class="order-info">
          <text class="order-id">订单号: {{item.orderId}}</text>
          <text class="order-time">{{item.timeStr}}</text>
        </view>
        <view class="tokens-info">
          <text class="tokens-num">+{{item.tokens}}</text>
          <text class="tokens-label">积分</text>
        </view>
      </view>
      <view class="card-right">
        <text class="amount">¥{{item.amount}}</text>
        <view class="status-tag {{item.statusClass}}">{{item.statusName}}</view>
      </view>
    </view>

    <view wx:if="{{loading}}" class="loading-more">
      <text>加载中...</text>
    </view>
    <view wx:if="{{noMore && list.length > 0}}" class="no-more">
      — 没有更多了 —
    </view>
  </view>
</view>