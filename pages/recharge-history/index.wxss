.page-recharge-history {
  min-height: 100vh;
  background: var(--bg);
  padding-bottom: 40rpx;
}

.stats-bar {
  background: #ffffff;
  padding: 28rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 60rpx;
  margin-bottom: 16rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.stat-num {
  font-size: 44rpx;
  font-weight: 800;
  color: var(--primary);
}

.stat-label {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.stat-divider {
  width: 1rpx;
  height: 56rpx;
  background: var(--border);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 160rpx 60rpx 80rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.empty-sub {
  font-size: 26rpx;
  color: var(--text-secondary);
  text-align: center;
  margin-bottom: 48rpx;
}

.empty-btn {
  width: 280rpx;
  height: 88rpx;
  border-radius: 44rpx;
  background: var(--primary);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 53, 0.3);
}

.empty-btn::after {
  border: none;
}

.recharge-list {
  padding: 0 24rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.recharge-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.card-left {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.order-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.order-id {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.order-time {
  font-size: 22rpx;
  color: var(--text-placeholder);
}

.tokens-info {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
  margin-top: 8rpx;
}

.tokens-num {
  font-size: 36rpx;
  font-weight: 800;
  color: #07c160;
}

.tokens-label {
  font-size: 24rpx;
  color: #07c160;
}

.card-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.amount {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.status-tag {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.status-success {
  background: #e8f5e9;
  color: #07c160;
}

.status-failed {
  background: #ffebee;
  color: #f44336;
}

.status-pending {
  background: #fff3e0;
  color: #ff9800;
}

.loading-more {
  text-align: center;
  padding: 32rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
}

.no-more {
  text-align: center;
  padding: 32rpx;
  font-size: 24rpx;
  color: var(--text-placeholder);
}