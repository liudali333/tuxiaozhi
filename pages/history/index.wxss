/* pages/history/index.wxss */

.page-history {
  min-height: 100vh;
  background: var(--bg);
  padding-bottom: 40rpx;
}

/* ── 顶部统计栏 ───────────────────────────────────── */
.stats-bar {
  background: #ffffff;
  padding: 28rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 60rpx;
  margin-bottom: 16rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.stat-num {
  font-size: 44rpx;
  font-weight: 800;
  color: var(--primary);
}

.stat-label {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.stat-divider {
  width: 1rpx;
  height: 56rpx;
  background: var(--border);
}

/* ── 搜索框 ─────────────────────────────────────── */
.search-bar {
  background: #ffffff;
  padding: 20rpx 24rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.search-input {
  flex: 1;
  height: 72rpx;
  background: var(--bg);
  border-radius: 36rpx;
  padding: 0 32rpx;
  font-size: 28rpx;
  color: var(--text-primary);
}

.search-input::placeholder {
  color: var(--text-placeholder);
}

.search-btn {
  width: 120rpx;
  height: 72rpx;
  background: var(--primary);
  color: #ffffff;
  border-radius: 36rpx;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  padding: 0;
}

.search-btn::after {
  border: none;
}

/* ── 空状态 ───────────────────────────────────────── */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 160rpx 60rpx 80rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.empty-sub {
  font-size: 26rpx;
  color: var(--text-secondary);
  text-align: center;
  margin-bottom: 48rpx;
}

.empty-btn {
  width: 280rpx;
  height: 88rpx;
  border-radius: 44rpx;
  background: var(--primary);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 53, 0.3);
}

.empty-btn::after {
  border: none;
}

/* ── 历史列表（列表式）──────────────────────────────── */
.history-list {
  padding: 0 24rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.history-item {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 20rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

/* 左侧信息 */
.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-width: 0;
}

.item-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.type-tag {
  font-size: 20rpx;
  font-weight: 600;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  flex-shrink: 0;
}

.tag-main {
  background: rgba(255, 107, 53, 0.1);
  color: var(--primary);
}

.tag-detail {
  background: rgba(79, 172, 254, 0.1);
  color: #4facfe;
}

.item-time {
  font-size: 22rpx;
  color: var(--text-placeholder);
}

.product-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-cost {
  font-size: 24rpx;
  color: var(--token-expense);
  font-weight: 600;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.cost-model {
  font-size: 22rpx;
  color: var(--text-secondary);
  font-weight: 400;
  background: var(--bg);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

/* 右侧图片 */
.item-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  overflow: hidden;
  position: relative;
  flex-shrink: 0;
  background: #f5f5f5;
}

.item-image .history-img {
  width: 100%;
  height: 100%;
  display: block;
}

.download-hint {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.5));
  color: #ffffff;
  font-size: 20rpx;
  text-align: center;
  padding: 20rpx 0 8rpx;
  opacity: 0;
  transition: opacity 0.2s;
}

.item-image:active .download-hint {
  opacity: 1;
}

/* ── 历史卡片列表（保留旧样式兼容）────────────────────── */
.history-card {
  background: #ffffff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.06);
}

/* 卡片头部 */
.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx 16rpx;
}

.card-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.card-time {
  font-size: 24rpx;
  color: var(--text-placeholder);
}

.card-cost {
  font-size: 24rpx;
  color: var(--token-expense);
  font-weight: 600;
}

/* 图片 */
.card-image {
  position: relative;
  width: 100%;
  background: #f5f5f5;
}

.ai-watermark {
  position: absolute;
  bottom: 16rpx;
  right: 16rpx;
  background: rgba(0, 0, 0, 0.45);
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 700;
  padding: 4rpx 10rpx;
  border-radius: 6rpx;
}

/* 商品信息 */
.card-info {
  padding: 16rpx 24rpx;
}

.card-info .product-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 6rpx;
}

.product-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.5;
}

/* 操作按钮 */
.card-actions {
  display: flex;
  gap: 12rpx;
  padding: 16rpx 24rpx 20rpx;
}

.action-btn {
  flex: 1;
  height: 72rpx;
  border-radius: 36rpx;
  font-size: 26rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.action-btn::after {
  border: none;
}

.action-save {
  background: rgba(255, 107, 53, 0.08);
  color: var(--primary);
  border: 2rpx solid rgba(255, 107, 53, 0.2);
}

.action-regen {
  background: rgba(79, 172, 254, 0.08);
  color: #4facfe;
  border: 2rpx solid rgba(79, 172, 254, 0.2);
}

/* ── 存储期限警告 ─────────────────────────────────── */
.warning-tip {
  background: linear-gradient(135deg, #fff3e0 0%, #ffe0b2 100%);
  padding: 16rpx 24rpx;
  margin: 0 16rpx 16rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  border: 1rpx solid rgba(255, 152, 0, 0.3);
}

.warning-icon {
  font-size: 32rpx;
  flex-shrink: 0;
}

.warning-text {
  font-size: 24rpx;
  color: #e65100;
  line-height: 1.5;
  flex: 1;
}

/* ── 加载更多 ─────────────────────────────────────── */
.loading-more {
  text-align: center;
  font-size: 26rpx;
  color: var(--text-placeholder);
  padding: 32rpx;
}

/* ── 分页按钮 ─────────────────────────────────────── */
.pagination {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 32rpx;
  padding: 32rpx;
  background: #ffffff;
  margin: 16rpx;
  border-radius: 12rpx;
}

.page-btn {
  padding: 16rpx 32rpx;
  background: var(--primary);
  color: #ffffff;
  border-radius: 8rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.page-btn.disabled {
  background: var(--border);
  color: var(--text-placeholder);
}

.page-info {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.line-clamp-2 {
  overflow: hidden;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}