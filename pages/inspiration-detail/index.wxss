.page-inspiration-detail {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 200rpx;
}

.result-image-container {
  position: relative;
  width: 100%;
  background: #fff;
}

.result-image {
  width: 100%;
  display: block;
}

.image-loading {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 16rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #f5f5f5;
  border-top-color: var(--primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.image-loading text {
  margin-top: 20rpx;
  font-size: 26rpx;
  color: #666;
}

.prompt-section {
  background: #fff;
  margin: 20rpx;
  padding: 30rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.prompt-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.prompt-label {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.copy-btn {
  display: flex;
  align-items: center;
  padding: 12rpx 24rpx;
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #fff;
}

.copy-btn:active {
  opacity: 0.8;
  transform: scale(0.95);
}

.prompt-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  word-break: break-all;
}

.ref-section {
  background: #fff;
  margin: 20rpx;
  padding: 30rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.ref-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.ref-label {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.ref-count {
  font-size: 24rpx;
  color: #999;
}

.ref-images-scroll {
  white-space: nowrap;
}

.ref-images-container {
  display: inline-flex;
  gap: 16rpx;
  padding: 8rpx 0;
}

.ref-image-item {
  flex-shrink: 0;
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.ref-image {
  width: 100%;
  height: 100%;
}

.tags-section {
  background: #fff;
  margin: 20rpx;
  padding: 30rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.tags-container {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 24rpx;
  background: linear-gradient(135deg, #fff0e6 0%, #ffe4cc 100%);
  border-radius: 32rpx;
  font-size: 24rpx;
  color: #ff6b35;
}

.back-btn {
  position: fixed;
  bottom: 40rpx;
  left: 50%;
  transform: translateX(-50%);
  padding: 20rpx 60rpx;
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
  border-radius: 50rpx;
  font-size: 28rpx;
  color: #fff;
  box-shadow: 0 4rpx 20rpx rgba(255, 107, 53, 0.3);
}

.back-btn:active {
  opacity: 0.9;
  transform: translateX(-50%) scale(0.95);
}
