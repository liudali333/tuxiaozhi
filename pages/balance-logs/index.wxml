<view class="page-balance-logs">
  <view wx:if="{{!loading && list.length === 0}}" class="empty-state">
    <view class="empty-icon">📋</view>
    <view class="empty-title">暂无积分记录</view>
    <view class="empty-sub">积分变动会显示在这里</view>
  </view>

  <view wx:else class="logs-list">
    <view
      wx:for="{{list}}"
      wx:key="id"
      class="log-card"
    >
      <view class="card-left">
        <view class="type-info">
          <text class="type-name {{item.isIncome ? 'income' : 'expense'}}">{{item.typeName}}</text>
          <text class="time-str">{{item.timeStr}}</text>
        </view>
        <view wx:if="{{item.remark}}" class="remark">{{item.remark}}</view>
        <view class="balance-info">余额: {{item.balanceAfter}}</view>
      </view>
      <view class="card-right">
        <text class="amount {{item.isIncome ? 'income' : 'expense'}}">
          {{item.isIncome ? '+' : ''}}{{item.amount}}
        </text>
        <text class="unit">积分</text>
      </view>
    </view>

    <view wx:if="{{loading}}" class="loading-more">
      <text>加载中...</text>
    </view>
    <view wx:if="{{noMore && list.length > 0}}" class="no-more">
      — 没有更多了 —
    </view>
  </view>
</view>