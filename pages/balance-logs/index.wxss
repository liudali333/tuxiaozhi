.page-balance-logs {
  min-height: 100vh;
  background: var(--bg);
  padding-bottom: 40rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 160rpx 60rpx 80rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.empty-sub {
  font-size: 26rpx;
  color: var(--text-secondary);
  text-align: center;
}

.logs-list {
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.log-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.card-left {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  flex: 1;
}

.type-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.type-name {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.type-name.income {
  color: var(--token-income);
}

.type-name.expense {
  color: var(--token-expense);
}

.time-str {
  font-size: 22rpx;
  color: var(--text-placeholder);
}

.remark {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 4rpx;
}

.balance-info {
  font-size: 22rpx;
  color: var(--text-placeholder);
  margin-top: 4rpx;
}

.card-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 4rpx;
}

.amount {
  font-size: 40rpx;
  font-weight: 800;
}

.amount.income {
  color: var(--token-income);
}

.amount.expense {
  color: var(--token-expense);
}

.unit {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.loading-more {
  text-align: center;
  padding: 32rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
}

.no-more {
  text-align: center;
  padding: 32rpx;
  font-size: 24rpx;
  color: var(--text-placeholder);
}