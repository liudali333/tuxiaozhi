.page-transfer {
  min-height: 100vh;
  background: linear-gradient(180deg, #FF6B35 0%, #F7931A 100%);
  padding-bottom: 40rpx;
}

/* 头部 */
.header {
  padding: 60rpx 40rpx 40rpx;
}

.balance-info {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
}

.balance-info .label {
  color: rgba(255, 255, 255, 0.8);
  font-size: 28rpx;
}

.balance-info .balance {
  color: #fff;
  font-size: 56rpx;
  font-weight: bold;
}

.tips {
  text-align: center;
  color: rgba(255, 255, 255, 0.7);
  font-size: 24rpx;
  margin-top: 20rpx;
}

/* 卡片 */
.card {
  margin: 20rpx 40rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
}

.input-section {
  margin-bottom: 30rpx;
}

.input-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 20rpx;
}

.input-wrapper {
  display: flex;
  gap: 20rpx;
}

.input {
  flex: 1;
  background: #f5f7fa;
  border-radius: 16rpx;
  padding: 28rpx 30rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
  min-height: 88rpx;
  box-sizing: border-box;
}

.input.full-width {
  width: 100%;
  box-sizing: border-box;
}

.query-btn {
  background: #FF6B35;
  color: #fff;
  border-radius: 16rpx;
  padding: 20rpx 36rpx;
  font-size: 28rpx;
  border: none;
  line-height: 1;
  margin: 0;
}

.query-btn::after {
  border: none;
}

.query-btn[disabled] {
  background: #ccc;
}

/* 用户信息 */
.user-info {
  display: flex;
  align-items: center;
  background: #f5f7fa;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-top: 20rpx;
}

.user-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  margin-right: 24rpx;
}

.user-detail {
  flex: 1;
}

.user-name {
  font-size: 32rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.user-id {
  font-size: 24rpx;
  color: #999;
}

.check-icon {
  font-size: 40rpx;
  color: #52c41a;
}

/* 底部按钮 */
.footer {
  padding: 60rpx 40rpx 40rpx;
}

.submit-btn {
  width: 100%;
  background: linear-gradient(135deg, #FF6B35 0%, #F7931A 100%);
  color: #fff;
  border-radius: 48rpx;
  padding: 30rpx 0;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  box-shadow: 0 10rpx 30rpx rgba(255, 107, 53, 0.3);
}

.submit-btn::after {
  border: none;
}

.submit-btn[disabled] {
  background: #ccc;
  box-shadow: none;
}
